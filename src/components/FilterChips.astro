---
/*
  Static filter-chip strip for the exercises and tools pages.
  Not interactive in MVP (no JS) — chips render as anchors with hash slugs.
  Future: hook up JS to actually filter the grid.
*/

interface Props {
  label?: string;
  items: { id: string; label: string; active?: boolean }[];
}

const { label, items } = Astro.props as Props;
---

<div class="filter-row" role="group" aria-label={label ?? 'Filter'}>
  {label && <p class="filter-label">{label}</p>}
  <ul class="filter-chips">
    {items.map((it) => (
      <li>
        <a
          href={`#${it.id}`}
          class:list={['filter-chip', { active: it.active }]}
        >{it.label}</a>
      </li>
    ))}
  </ul>
</div>

<style>
  .filter-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--ak-space-3);
    margin: 0 0 var(--ak-space-5);
  }

  .filter-label {
    font-family: var(--ak-font-mono);
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    color: var(--ak-ink-soft);
    margin: 0;
    letter-spacing: 0.04em;
  }

  .filter-chips {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--ak-space-2);
  }

  .filter-chip {
    display: inline-block;
    font-family: var(--ak-font-mono);
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 4px 10px;
    background: var(--ak-hazelnut-container);
    color: var(--ak-blueberry-p);
    border-radius: 999px;
    text-decoration: none;
  }

  .filter-chip:hover {
    background: var(--ak-strawberry-container);
  }

  .filter-chip.active {
    background: var(--ak-raspberry-h);
    color: var(--ak-vanilla-bg);
  }
</style>
