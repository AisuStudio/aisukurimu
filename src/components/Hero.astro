---
/*
  Hero section for the home page.
  Dark blueberry gradient background with eyebrow, headline, subtitle.
*/

interface Props {
  eyebrow?: string;
  headline: string;
  subtitle?: string;
}

const {
  eyebrow = 'Hacking / Coding / Making / Systemisches Denken',
  headline,
  subtitle,
} = Astro.props as Props;
---

<section class="hero" aria-label="Einstieg">
  <div class="ak-container hero-inner">
    <p class="ak-eyebrow ak-eyebrow-dark hero-eyebrow">{eyebrow}</p>
    <h1 class="hero-headline">{headline}</h1>
    {subtitle && <p class="hero-subtitle">{subtitle}</p>}
  </div>
</section>

<style>
  .hero {
    background: linear-gradient(135deg, var(--ak-blueberry-p) 0%, var(--ak-blueberry-dark) 100%);
    color: var(--ak-vanilla-bg);
    padding: var(--ak-space-8) 0;
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    gap: var(--ak-space-5);
    max-width: 900px;
  }

  .hero-eyebrow {
    margin: 0;
  }

  .hero-headline {
    font-family: var(--ak-font-display);
    color: var(--ak-vanilla-bg);
    font-size: var(--ak-size-hero-mobile);
    line-height: 1.1;
    margin: 0;
    /* sentence case headline per XD — relies on the source string */
    text-transform: none;
  }

  .hero-subtitle {
    font-family: var(--ak-font-body);
    font-size: 1.125rem;
    color: var(--ak-vanilla-bg);
    margin: 0;
    line-height: 1.5;
    opacity: 0.92;
    max-width: 650px;
  }

  @media (min-width: 768px) {
    .hero {
      padding: var(--ak-space-9) 0;
    }
    .hero-headline {
      font-size: var(--ak-size-hero-desktop);
    }
    .hero-subtitle {
      font-size: 1.25rem;
    }
  }
</style>
