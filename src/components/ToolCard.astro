---
/*
  Card for a tool entry. Strawberry container background; shows
  name, tagline, level chip, category and platform chips, link out.
*/

interface Props {
  name: string;
  tagline?: string;
  level: 'basic' | 'medium' | 'advanced';
  categories: string[];
  platforms: string[];
  price: 'free' | 'paid' | 'school-license';
  url?: string;
  description?: string;
  aisuTip?: string;
}

const levelLabel: Record<Props['level'], string> = {
  basic: 'Basic',
  medium: 'Medium',
  advanced: 'Fortgeschritten',
};

const priceLabel: Record<Props['price'], string> = {
  free: 'Kostenlos',
  paid: 'Kostenpflichtig',
  'school-license': 'Schul-Lizenz',
};

const props = Astro.props as Props;
---

<article class="tool-card">
  <header class="tool-head">
    <p class="ak-eyebrow tool-level">{levelLabel[props.level]} · {priceLabel[props.price]}</p>
    <h3 class="tool-name">{props.name}</h3>
    {props.tagline && <p class="tool-tagline">{props.tagline}</p>}
  </header>

  {props.description && <p class="tool-desc">{props.description}</p>}

  <ul class="tool-chips" aria-label="Kategorien und Plattformen">
    {props.categories.map((c) => <li class="chip chip-cat">{c}</li>)}
    {props.platforms.map((p) => <li class="chip chip-plat">{p}</li>)}
  </ul>

  {props.aisuTip && (
    <p class="tool-tip">
      <strong>Aisu-Tipp:</strong> {props.aisuTip}
    </p>
  )}

  {props.url && (
    <a class="tool-link" href={props.url} target="_blank" rel="noopener noreferrer">
      {props.url.replace(/^https?:\/\//, '').replace(/\/$/, '')} ↗
    </a>
  )}
</article>

<style>
  .tool-card {
    display: flex;
    flex-direction: column;
    gap: var(--ak-space-3);
    padding: var(--ak-space-5);
    background: var(--ak-strawberry-container);
    border-radius: var(--ak-radius-md);
    height: 100%;
  }

  .tool-head { display: flex; flex-direction: column; gap: var(--ak-space-2); }

  .tool-level { margin: 0; }

  .tool-name {
    font-family: var(--ak-font-display);
    color: var(--ak-blueberry-p);
    font-size: 1.5rem;
    line-height: var(--ak-leading-display);
    margin: 0;
  }

  .tool-tagline {
    font-family: var(--ak-font-body);
    font-style: italic;
    font-size: 1rem;
    color: var(--ak-ink-soft);
    margin: 0;
  }

  .tool-desc {
    font-family: var(--ak-font-body);
    font-size: 0.95rem;
    color: var(--ak-ink);
    margin: 0;
    line-height: 1.5;
  }

  .tool-chips {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--ak-space-2);
  }

  .chip {
    font-family: var(--ak-font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 2px 8px;
    border-radius: 999px;
  }

  .chip-cat {
    background: var(--ak-vanilla-bg);
    color: var(--ak-blueberry-p);
  }

  .chip-plat {
    background: var(--ak-hazelnut-container);
    color: var(--ak-blueberry-p);
  }

  .tool-tip {
    font-family: var(--ak-font-body);
    font-size: 0.9rem;
    color: var(--ak-ink);
    background: var(--ak-vanilla-bg);
    padding: var(--ak-space-3) var(--ak-space-4);
    border-radius: var(--ak-radius-sm);
    margin: 0;
    line-height: 1.5;
  }

  .tool-tip strong {
    color: var(--ak-raspberry-h);
    font-weight: 700;
  }

  .tool-link {
    font-family: var(--ak-font-mono);
    font-weight: 700;
    font-size: 0.85rem;
    color: var(--ak-blueberry-p);
    text-decoration: none;
    margin-top: auto;
  }

  .tool-link:hover { color: var(--ak-raspberry-h); }
</style>
