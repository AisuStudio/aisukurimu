---
/*
  Site footer — Brand v2.
  Vanilla-tile logo box left, three link columns, raspberry hairline above
  the copyright. Same dark background as the rest of the page.
*/
import { url } from '../lib/url';
import { LINKEDIN_URL, GITHUB_URL } from '../consts';
---

<hr class="hr" />

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">

      <div class="footer-logo">
        <img src={url('/brand/AK_Logo_Blue.svg')} alt="aisukurimu Logo" width="64" height="64" />
      </div>

      <div class="footer-col">
        <h3 class="footer-col-head">Plattform</h3>
        <a class="footer-links" href={url('/werkzeuge/')}>Werkzeuge</a>
        <a class="footer-links" href={url('/uebungen/')}>Übungen</a>
        <a class="footer-links" href={url('/downloads/')}>Downloads</a>
        <a class="footer-links" href={url('/medien/')}>Medien</a>
      </div>

      <div class="footer-col">
        <h3 class="footer-col-head">Info</h3>
        <a class="footer-links" href={url('/ueber/')}>Über</a>
        <a class="footer-links" href={url('/impressum/')}>Impressum</a>
        <a class="footer-links" href={url('/datenschutz/')}>Datenschutz</a>
        <a class="footer-links" href="mailto:hi@aisukurimu.com">Kontakt</a>
      </div>

      <div class="footer-col">
        <h3 class="footer-col-head">More</h3>
        <a class="footer-links" href={LINKEDIN_URL} target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <a class="footer-links" href={GITHUB_URL} target="_blank" rel="noopener noreferrer">GitHub</a>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="caption">Copyright aisu.studio 2026</p>
    </div>
  </div>
</footer>

<style>
  .site-footer { padding: var(--sp-3xl) 0 var(--sp-xl); }

  .footer-grid {
    display: grid;
    grid-template-columns: auto 1fr 1fr 1fr;
    gap: var(--sp-2xl);
    align-items: start;
  }

  .footer-logo {
    background: var(--ak-vanilla-bg);
    width: 96px;
    height: 96px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--sp-md);
  }
  .footer-logo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: var(--sp-md);
  }

  .footer-col-head {
    font-family: "iA Writer Mono S", monospace;
    font-weight: bold;
    font-size: 16px;
    line-height: 20px;
    color: var(--ak-lemon-accent);
    text-transform: uppercase;
    margin: 0;
  }

  .footer-bottom {
    margin-top: var(--sp-2xl);
    padding-top: var(--sp-lg);
    border-top: 1px solid var(--ak-raspberry-h);
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--sp-xl);
    }
  }
</style>
