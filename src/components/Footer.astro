---
/*
  Site footer: small Aisu mark, three link columns, copyright bar.
  Background: Strawberry container per XD design.
*/
import { LINKEDIN_URL } from '../consts';

const year = new Date().getFullYear();

const columns = [
  {
    title: 'Plattform',
    links: [
      { href: '/tools/',     label: 'Tools' },
      { href: '/exercises/', label: 'Exercises' },
      { href: '/raetsel/',   label: 'Rätsel' },
      { href: '/media/',     label: 'Media' },
    ],
  },
  {
    title: 'Info',
    links: [
      { href: '/about/',       label: 'About' },
      { href: '/impressum/',   label: 'Impressum' },
      { href: '/datenschutz/', label: 'Datenschutz' },
      { href: 'mailto:hi@aisukurimu.com', label: 'Kontakt' },
    ],
  },
  {
    title: 'More',
    links: [
      { href: LINKEDIN_URL, label: 'LinkedIn', external: true },
      { href: 'https://github.com/', label: 'GitHub', external: true },
    ],
  },
];
---

<footer class="site-footer">
  <div class="ak-container footer-inner">
    <div class="footer-mark">
      <img src="/logos/AK_Logo_Mob.svg" alt="aisukurimu" width="64" height="69" />
    </div>

    <div class="footer-cols">
      {columns.map((col) => (
        <div class="footer-col">
          <h3 class="footer-heading">{col.title}</h3>
          <ul>
            {col.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  target={link.external ? '_blank' : undefined}
                  rel={link.external ? 'noopener noreferrer' : undefined}
                >{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>

  <div class="ak-container footer-bottom">
    <small>© aisu studio {year}</small>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--ak-strawberry-container);
    color: var(--ak-blueberry-p);
    padding: var(--ak-space-8) 0 var(--ak-space-5);
    margin-top: var(--ak-space-9);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--ak-space-7);
    align-items: start;
  }

  .footer-mark img {
    width: 64px;
    height: auto;
  }

  .footer-cols {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--ak-space-6);
  }

  .footer-heading {
    font-family: var(--ak-font-mono);
    font-weight: 700;
    font-size: 0.875rem;
    color: var(--ak-raspberry-h);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 var(--ak-space-3);
  }

  .footer-col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--ak-space-2);
  }

  .footer-col a {
    font-family: var(--ak-font-body);
    font-size: 0.95rem;
    color: var(--ak-blueberry-p);
    text-decoration: none;
  }

  .footer-col a:hover {
    text-decoration: underline;
    text-decoration-color: var(--ak-raspberry-h);
  }

  .footer-bottom {
    margin-top: var(--ak-space-7);
    padding-top: var(--ak-space-4);
    border-top: 1px solid rgba(38, 36, 123, 0.15);
    color: var(--ak-blueberry-p);
    font-size: 0.85rem;
  }

  @media (min-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr 3fr;
      gap: var(--ak-space-8);
    }
    .footer-mark img {
      width: 80px;
    }
    .footer-cols {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
