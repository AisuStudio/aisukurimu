---
/*
  Site header — Brand v2.
  Desktop: 4-column grid: AisuAscii | Wordmark+Tagline | Hauptnav | Meta
  Mobile: Spalten 1+2 sichtbar, 3+4 ausgeblendet, `=`-Toggle rechts.

  Mobile drawer uses anchor + :target (no JS for MVP); JS-enhancement can
  swap this out later without changing the component API.
*/
import AisuAscii from './AisuAscii.astro';
import HeaderLink from './HeaderLink.astro';
import { url } from '../lib/url';
import { LINKEDIN_URL, GITHUB_URL } from '../consts';

const home = url('/');
---

<header class="site-header">
  <div class="container">
    <div class="site-header-inner">

      {/* Col 1: ASCII Aisu */}
      <AisuAscii />

      {/* Col 2: Wordmark + Tagline (single click target → home) */}
      <a class="brand-link" href={home} aria-label="aisukurimu — Digital Literacy for Kids, Startseite">
        <div class="wordmark-col">
          <span class="wordmark">
            <span class="l">Lab.</span>
            <span class="l">Aisu</span>
            <span class="l">.Studio</span>
          </span>
          <span class="tagline">Digital<br />Literacy<br />for Kids</span>
        </div>
      </a>

      {/* Col 3: Hauptnav */}
      <nav class="nav-col" aria-label="Hauptnavigation">
        <HeaderLink href="/werkzeuge/">Werkzeuge</HeaderLink>
        <HeaderLink href="/uebungen/">Übungen</HeaderLink>
        <HeaderLink href="/medien/">Medien</HeaderLink>
      </nav>

      {/* Col 4: Meta (right-aligned) */}
      <nav class="nav-col meta" aria-label="Meta-Navigation">
        <HeaderLink href="/en/" disabled>Switch to English</HeaderLink>
        <HeaderLink href={LINKEDIN_URL} external>LinkedIn</HeaderLink>
        <HeaderLink href={GITHUB_URL} external>GitHub</HeaderLink>
        <HeaderLink href="/ueber/">Über</HeaderLink>
      </nav>

      {/* Mobile-only ASCII-burger; anchor-based open via :target */}
      <a class="mobile-toggle" href="#menu" aria-label="Menü öffnen">=</a>
    </div>

    {/* Mobile drawer — desktop hides it via CSS */}
    <div id="menu" class="mobile-drawer">
      <a href="#" class="mobile-close" aria-label="Menü schließen">×</a>
      <nav class="mobile-nav" aria-label="Mobil-Navigation">
        <HeaderLink href="/werkzeuge/">Werkzeuge</HeaderLink>
        <HeaderLink href="/uebungen/">Übungen</HeaderLink>
        <HeaderLink href="/medien/">Medien</HeaderLink>
        <HeaderLink href="/en/" disabled>Switch to English</HeaderLink>
        <HeaderLink href={LINKEDIN_URL} external>LinkedIn</HeaderLink>
        <HeaderLink href={GITHUB_URL} external>GitHub</HeaderLink>
        <HeaderLink href="/ueber/">Über</HeaderLink>
      </nav>
    </div>
  </div>
</header>

<hr class="hr" />

<style>
  .site-header { padding: var(--sp-xl) 0; }

  /* Editorial 12-column grid: ASCII | Brand | empty | Hauptnav | empty | Meta */
  .site-header-inner {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    column-gap: 16px;
    align-items: start;
  }
  .site-header-inner > :global(.ascii-aisu) { grid-column: 1; }
  .site-header-inner > .brand-link { grid-column: 2; }
  .site-header-inner > .nav-col:not(.meta) { grid-column: 4 / span 2; }
  .site-header-inner > .nav-col.meta { grid-column: 11 / span 2; justify-self: end; }

  /* Wordmark column */
  .brand-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .wordmark-col {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .wordmark {
    font-family: "iA Writer Mono S", monospace;
    font-weight: bold;
    font-size: 14px;
    line-height: 16px;
    color: var(--ak-vanilla-bg);
  }
  .wordmark .l { display: block; }
  .tagline {
    font-family: "iA Writer Mono S", monospace;
    font-weight: bold;
    font-size: 14px;
    line-height: 16px;
    color: var(--ak-raspberry-h);
  }
  .brand-link:hover .wordmark,
  .brand-link:focus-visible .wordmark,
  .brand-link:hover .tagline,
  .brand-link:focus-visible .tagline { color: var(--ak-lemon-accent); }

  /* Nav columns — gap = one line-height (16px), so each item is followed
     by one empty line (matches the XD spec where nav uses real blank
     lines rather than inflated line-heights). */
  .nav-col {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .nav-col.meta {
    text-align: right;
    align-items: flex-end;
  }
  /* Per XD: only Hauptnav is uppercase. Meta column keeps its native
     casing ("Switch to English", "LinkedIn", "Über"). */
  .nav-col.meta :global(.nav-item) {
    text-transform: none;
  }

  /* Mobile drawer */
  .mobile-drawer {
    display: none;
  }
  .mobile-close { display: none; }

  /* -- Mobile -- */
  @media (max-width: 768px) {
    .site-header-inner {
      grid-template-columns: auto 1fr auto;
      gap: var(--sp-md);
      align-items: center;
    }
    .site-header-inner > .nav-col { display: none; }

    .mobile-drawer {
      display: block;
      position: fixed;
      inset: 0;
      background: var(--ak-bg-dark);
      padding: var(--sp-2xl) var(--sp-lg);
      transform: translateX(100%);
      transition: transform 0.2s ease;
      z-index: 50;
      overflow-y: auto;
    }
    .mobile-drawer:target {
      transform: translateX(0);
    }
    .mobile-close {
      display: inline-block;
      font-family: "iA Writer Mono S", monospace;
      font-size: 32px;
      line-height: 1;
      color: var(--ak-raspberry-h);
      text-decoration: none;
      position: absolute;
      top: var(--sp-lg);
      right: var(--sp-lg);
    }
    .mobile-nav {
      display: flex;
      flex-direction: column;
      gap: var(--sp-lg);
      margin-top: var(--sp-3xl);
    }
  }
</style>
