---
/*
  Sticky site header with logo on the left, primary navigation on the right.
  Mobile: nav collapses behind a CSS-only hamburger toggle.
*/

const nav = [
  { href: '/tools/',     label: 'Tools' },
  { href: '/exercises/', label: 'Exercises' },
  { href: '/raetsel/',   label: 'Rätsel' },
  { href: '/media/',     label: 'Media' },
  { href: '/about/',     label: 'About' },
];

const pathname = Astro.url.pathname;
---

<header class="site-header">
  <div class="ak-container header-inner">
    <a href="/" class="logo" aria-label="aisukurimu — Startseite">
      <img src="/logos/AK_Logo_lockUp_Long.svg" alt="aisukurimu" width="190" height="64" />
    </a>

    {/* CSS-only mobile toggle: a checkbox controls the menu state */}
    <input type="checkbox" id="nav-toggle" class="nav-toggle" aria-hidden="true" />
    <label for="nav-toggle" class="hamburger" aria-label="Menü öffnen / schließen">
      <span></span><span></span><span></span>
    </label>

    <nav class="site-nav" aria-label="Hauptnavigation">
      <ul>
        {nav.map((item) => {
          const active = pathname === item.href || (item.href !== '/' && pathname.startsWith(item.href));
          return (
            <li>
              <a href={item.href} class:list={['nav-link', { active }]}>{item.label}</a>
            </li>
          );
        })}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--ak-vanilla-bg);
    border-bottom: 1px solid rgba(38, 36, 123, 0.06);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: var(--ak-space-4);
    padding-bottom: var(--ak-space-4);
    gap: var(--ak-space-5);
  }

  .logo {
    display: inline-flex;
    text-decoration: none;
  }

  .logo img {
    height: 40px;
    width: auto;
  }

  .site-nav ul {
    display: flex;
    flex-wrap: wrap;
    gap: var(--ak-space-6);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    font-family: var(--ak-font-mono);
    font-weight: 700;
    font-size: 0.95rem;
    text-transform: uppercase;
    color: var(--ak-raspberry-h);
    text-decoration: none;
    letter-spacing: 0.04em;
    padding-bottom: 2px;
    border-bottom: 2px solid transparent;
  }

  .nav-link:hover,
  .nav-link:focus-visible {
    color: var(--ak-blueberry-p);
    border-bottom-color: var(--ak-blueberry-p);
  }

  .nav-link.active {
    border-bottom-color: var(--ak-raspberry-h);
  }

  /* Hide the mobile toggle by default (desktop) */
  .nav-toggle,
  .hamburger {
    display: none;
  }

  /* -- Mobile layout -- */
  @media (max-width: 767px) {
    .hamburger {
      display: inline-flex;
      flex-direction: column;
      justify-content: space-between;
      width: 28px;
      height: 22px;
      cursor: pointer;
    }

    .hamburger span {
      display: block;
      height: 3px;
      width: 100%;
      background: var(--ak-blueberry-p);
      border-radius: 2px;
      transition: transform 0.2s ease;
    }

    .site-nav {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--ak-vanilla-bg);
      border-bottom: 1px solid rgba(38, 36, 123, 0.08);
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.25s ease;
    }

    .site-nav ul {
      flex-direction: column;
      gap: var(--ak-space-4);
      padding: var(--ak-space-5);
    }

    .nav-toggle:checked ~ .site-nav {
      max-height: 400px;
    }

    .logo img {
      height: 32px;
    }
  }
</style>
