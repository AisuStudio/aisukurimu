---
/*
  Exercise card — Brand v2.
  16:9 image slot on top, body with lemon caption + vanilla description +
  raspberry tag list. Border 1px raspberry, hover-lift -2px.
*/
import { url } from '../lib/url';

interface Props {
  href: string;
  title: string;
  description: string;
  category: string;
  level: number;
  image?: string;
  tags?: string[];
}

const { href, title, description, category, level, image, tags = [] } = Astro.props as Props;
const imageSrc = image ? url(image) : null;
---

<a class="ex-card" href={href}>
  {imageSrc ? (
    <img class="ex-image" src={imageSrc} alt="" />
  ) : (
    <div class="ex-image placeholder-image" role="img" aria-label="Platzhalter"></div>
  )}
  <div class="ex-body">
    <h3 class="h2-lemon ex-caption">{title}</h3>
    <p class="p-small-vanilla ex-desc">{description}</p>
    {tags.length > 0 && (
      <p class="caption-raspberry ex-tags">{tags.slice(0, 4).join(', ')}</p>
    )}
    <p class="caption-raspberry ex-meta">{category} · Level {level}</p>
  </div>
</a>

<style>
  .ex-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--ak-raspberry-h);
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    transition: transform 0.18s ease;
    background: transparent;
  }

  .ex-card:hover,
  .ex-card:focus-visible {
    transform: translateY(-2px);
  }

  .ex-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
  }

  .ex-body {
    padding: var(--sp-lg);
    display: flex;
    flex-direction: column;
    gap: var(--sp-md);
  }

  /* Smaller variant of h2-lemon for use inside cards */
  .ex-caption {
    font-size: 16px;
    line-height: 20px;
  }

  .ex-desc { /* Inherits .p-small-vanilla styling */ }
  .ex-tags { margin: 0; }
  .ex-meta { margin: 0; opacity: 0.7; }
</style>
