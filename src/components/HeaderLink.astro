---
/*
  Header navigation link. Applies the global .nav-item class and .active
  state when the current pathname starts with the link's resolved path.
  Internal paths are routed through the base-aware url() helper.
*/
import { url } from '../lib/url';

interface Props {
  href: string;
  external?: boolean;
  disabled?: boolean;
  class?: string;
}

const { href, external = false, disabled = false, class: extraClass = '' } = Astro.props as Props;

const finalHref = external ? href : url(href);
const pathname = Astro.url.pathname;
const home = url('/');

const isActive =
  !external &&
  !disabled &&
  finalHref !== home &&
  pathname.startsWith(finalHref);

const classList = ['nav-item', extraClass, isActive ? 'active' : '', disabled ? 'disabled' : '']
  .filter(Boolean)
  .join(' ');
---

<a
  href={finalHref}
  class={classList}
  target={external ? '_blank' : undefined}
  rel={external ? 'noopener noreferrer' : undefined}
  aria-disabled={disabled ? 'true' : undefined}
>
  <slot />
</a>
