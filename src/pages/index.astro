---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ExerciseCard from '../components/ExerciseCard.astro';
import { LINKEDIN_URL } from '../consts';
import { url } from '../lib/url';

const exercises = (await getCollection('uebungen', ({ data }) => data.published !== false))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<Base title="Lerne die Welt wie ein Hacker zu lesen">
  {/* ===================== HERO ===================== */}
  <section class="home-hero">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-text">
          <div class="hero-eyebrow">
            <span class="caption">HACKING</span>
            <span class="caption pipe">|</span>
            <span class="caption">CODING MAKING</span>
            <span class="caption pipe">|</span>
            <span class="caption">SYSTEMISCHES</span>
            <span class="caption pipe">|</span>
            <span class="caption">DENKEN</span>
          </div>
          <h1 class="hero-title-vanilla">Lerne die Welt wie ein Hacker zu lesen</h1>
          <p class="hero-lede p-big">
            Entdecke die unsichtbaren Strukturen hinter der Technik. Wir lernen nicht nur
            programmieren, sondern verstehen, wie Systeme funktionieren, wie sich Code verhält
            und warum manche Dinge so sind, wie sie sind.
          </p>
        </div>
        <div class="hero-image-slot">
          <img class="hero-image" src={url('/images/AK_INDEX_SPLASH.jpg')} alt="Aisu im Regen" />
        </div>
      </div>
    </div>
  </section>

  <hr class="hr" />

  {/* ===================== ÜBUNGEN ===================== */}
  <section class="home-uebungen">
    <div class="container">
      <h2 class="h1-vanilla cursor">Übungen</h2>
      <p class="section-intro p-small-vanilla">
        Kleine, eigenständige Aufgaben — von „Hallo Brawl Stars" bis „mein Rechner unter der Lupe".
        Du kannst sie in beliebiger Reihenfolge angehen.
      </p>

      <div class="cards-grid">
        {exercises.map((entry) => (
          <ExerciseCard
            href={url(`/uebungen/${entry.id}/`)}
            title={entry.data.title}
            description={entry.data.description}
            category={entry.data.category}
            level={entry.data.level}
            image={entry.data.image}
            tags={entry.data.tags}
          />
        ))}
      </div>

      <p class="cta-row">
        <a class="link-big" href={url('/uebungen/')}>Alle Übungen</a>
      </p>
    </div>
  </section>

  <hr class="hr" />

  {/* ===================== WER MACHT DAS HIER ===================== */}
  <section class="home-ueber">
    <div class="container">
      <h2 class="h1-vanilla cursor">Wer macht das hier?</h2>
      <div class="ueber-grid">
        <div class="ueber-text">
          <p class="p-small-vanilla">
            Hi, ich bin Dominik. Ich glaube daran, dass Technologie kein magisches Rätsel sein sollte,
            sondern ein Werkzeug, das jeder verstehen kann. Mit aisukurimu bringe ich Kindern und
            Neugierigen bei, die unsichtbaren Strukturen hinter den Apps und Spielen zu sehen —
            und sie nicht nur zu nutzen, sondern zu gestalten.
          </p>
          <p class="p-small-vanilla">
            Hier geht es nicht nur um „Code", sondern um die Art und Weise, wie wir Probleme lösen
            und unsere digitale Umgebung aktiv gestalten, anstatt sie nur zu konsumieren.
          </p>
          <a class="link-big" href={LINKEDIN_URL} target="_blank" rel="noopener noreferrer">
            Finde mich auf LinkedIn
          </a>
        </div>
        <div>
          <img class="portrait-circle" src={url('/images/AS-LinkedIn_Photo.jpg')} alt="Portrait Dominik" />
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  /* -- Hero -- */
  .home-hero { padding: var(--sp-3xl) 0; }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-xl);
    align-items: center;
  }

  .hero-eyebrow {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-sm);
    margin: 0 0 var(--sp-md);
  }
  .hero-eyebrow .pipe { color: var(--ak-raspberry-h); }

  .hero-lede { margin-top: var(--sp-lg); }

  .hero-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
  }

  /* -- Übungen section -- */
  .home-uebungen { padding: var(--sp-3xl) 0; }
  .section-intro { max-width: 540px; margin-top: var(--sp-md); }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-lg);
    margin-top: var(--sp-2xl);
  }

  .cta-row {
    margin: var(--sp-2xl) 0 0;
  }

  /* -- Wer macht das hier -- */
  .home-ueber { padding: var(--sp-3xl) 0; }
  .ueber-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-xl);
    align-items: center;
    margin-top: var(--sp-xl);
  }
  .ueber-text { display: flex; flex-direction: column; gap: var(--sp-md); }

  .portrait-circle {
    width: 280px;
    height: 280px;
    border-radius: 50%;
    object-fit: cover;
    margin-left: auto;
    display: block;
  }
  @media (max-width: 768px) {
    .portrait-circle { width: 200px; height: 200px; margin: 0 auto; }
  }

  /* -- Responsive — keep 2-col grids alive longer, collapse only at true mobile -- */
  @media (max-width: 900px) {
    .cards-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 720px) {
    .hero-grid,
    .ueber-grid { grid-template-columns: 1fr; }
    .cards-grid { grid-template-columns: 1fr; }
  }
</style>
