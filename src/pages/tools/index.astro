---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ToolCard from '../../components/ToolCard.astro';
import FilterChips from '../../components/FilterChips.astro';

const tools = (await getCollection('tools'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const levels: { id: string; label: string; key: 'basic' | 'medium' | 'advanced' }[] = [
  { id: 'basic',    label: 'Basic — fürs erste Mal',          key: 'basic' },
  { id: 'medium',   label: 'Medium — wenn du warmgespielt bist', key: 'medium' },
  { id: 'advanced', label: 'Fortgeschritten — für später',     key: 'advanced' },
];

const categories = Array.from(new Set(tools.flatMap((t) => t.data.categories)));
const filters = [
  { id: 'all', label: 'Alle', active: true },
  ...categories.map((c) => ({ id: c, label: c })),
];
---

<Base
  title="Werkzeuge"
  description="Alle Werkzeuge im aisukurimu-Kurs, sortiert nach Schwierigkeit. Für Mac und Windows."
>
  <header class="page-head ak-container">
    <p class="ak-eyebrow">Werkzeugkasten</p>
    <h1 class="ak-section-title page-title">Tools</h1>
    <p class="page-lead">
      Eine Übersicht aller Werkzeuge im Kurs — von „einfach loslegen" bis
      „wenn du etwas geübt hast". Klick dich durch, viele kannst du direkt im Browser öffnen.
    </p>
  </header>

  <section class="ak-container page-body">
    <FilterChips label="Kategorie" items={filters} />

    {levels.map((lvl) => {
      const inLevel = tools.filter((t) => t.data.level === lvl.key);
      if (inLevel.length === 0) return null;
      return (
        <section class="level-group" id={lvl.id}>
          <h2 class="level-title">{lvl.label}</h2>
          <div class="grid">
            {inLevel.map((t) => (
              <ToolCard
                name={t.data.name}
                tagline={t.data.tagline}
                level={t.data.level}
                categories={t.data.categories}
                platforms={t.data.platforms}
                price={t.data.price}
                url={t.data.url}
                aisuTip={t.data.aisuTip}
                description={t.body}
              />
            ))}
          </div>
        </section>
      );
    })}
  </section>
</Base>

<style>
  .page-head {
    padding-top: var(--ak-space-7);
    padding-bottom: var(--ak-space-5);
  }
  .page-title { margin: var(--ak-space-2) 0 var(--ak-space-3); }
  .page-lead {
    font-size: 1.1rem;
    color: var(--ak-ink-soft);
    max-width: 700px;
    margin: 0;
  }
  .page-body { padding-bottom: var(--ak-space-8); }

  .level-group {
    margin-top: var(--ak-space-7);
  }

  .level-title {
    font-family: var(--ak-font-display);
    color: var(--ak-blueberry-p);
    font-size: 1.5rem;
    margin: 0 0 var(--ak-space-5);
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--ak-space-5);
  }
  @media (min-width: 640px) { .grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .grid { grid-template-columns: repeat(3, 1fr); } }
</style>
