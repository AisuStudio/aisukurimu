---
import Base from '../../layouts/Base.astro';
import NicknameModal from '../../components/NicknameModal.astro';
import { url } from '../../lib/url';
---

<Base title="Aufgabe 10 — Terminal-Spiel" description="Lerne die ersten Terminal-Befehle — direkt im Browser, ohne Installation.">
<style is:global>body { --wurst-color: var(--ak-container); }</style>
<NicknameModal />
  <section class="ts-page">
    <div class="container">
      <img class="ts-hero" src={url('/images/AK_EX_0010.jpg')} alt="Terminal-Spiel" />
      <h1 class="h1-vanilla">Terminal-Spiel</h1>
      <p class="p-big ts-intro">
        Kein Download, keine Einrichtung. Tippe echte Terminal-Befehle — und sieh was passiert.
      </p>

      <div class="ts-mission">
        <p class="ts-mission-text">Deine erste Mission: Finde heraus wer du bist und wo du bist — und öffne die Geheimakte.</p>
        <p class="ts-mission-start">Fang an mit <code class="ts-code">whoami</code> <span class="ts-etym">(engl. „Who am I?" → Wer bin ich?)</span> — alle Befehle zeigt dir <code class="ts-code">help</code></p>
      </div>

      <ul class="ts-checklist" id="ts-checklist">
        <li class="ts-check" data-cmd="whoami">
          <span class="ts-check-box">☐</span>
          <span>Finde deinen Benutzernamen — <code class="ts-code">whoami</code></span>
        </li>
        <li class="ts-check" data-cmd="hostname">
          <span class="ts-check-box">☐</span>
          <span>Finde den Namen dieses Rechners — <code class="ts-code">hostname</code></span>
        </li>
        <li class="ts-check" data-cmd="ifconfig">
          <span class="ts-check-box">☐</span>
          <span>Schau deine lokale IP-Adresse an — <code class="ts-code">ifconfig</code></span>
        </li>
        <li class="ts-check" data-cmd="curl ifconfig.me">
          <span class="ts-check-box">☐</span>
          <span>Finde deine externe IP — <code class="ts-code">curl ifconfig.me</code></span>
        </li>
        <li class="ts-check" data-cmd="ping">
          <span class="ts-check-box">☐</span>
          <span>Ping einen Rechner an — <code class="ts-code">ping lab.aisu.studio</code></span>
        </li>
        <li class="ts-check" data-cmd="cat geheimakte.txt">
          <span class="ts-check-box">☐</span>
          <span>Öffne die Geheimakte — <code class="ts-code">cat geheimakte.txt</code></span>
        </li>
      </ul>

      <p class="ts-all-done" id="ts-alldone">✓ Mission erfüllt — du kennst jetzt die wichtigsten Terminal-Befehle!</p>

      <div class="ts-window">
        <div class="ts-titlebar">
          <span class="ts-dot ts-dot--red"></span>
          <span class="ts-dot ts-dot--yellow"></span>
          <span class="ts-dot ts-dot--green"></span>
          <span class="ts-title">aisu@lab — terminal</span>
        </div>

        <div class="ts-output" id="ts-output" aria-live="polite" aria-label="Terminal Ausgabe"></div>

        <div class="ts-inputrow">
          <span class="ts-prompt">aisu@lab:~$</span>
          <input
            class="ts-input"
            id="ts-input"
            type="text"
            autocomplete="off"
            autocorrect="off"
            autocapitalize="off"
            spellcheck="false"
            aria-label="Terminal Eingabe"
            placeholder="Befehl eingeben …"
          />
        </div>
      </div>

      <div class="ts-hint">
        <span class="ts-hint-label">Tipp:</span> Drücke <kbd>Enter</kbd> um einen Befehl abzuschicken · <kbd>↑</kbd> für letzte Eingabe
      </div>
    </div>
  </section>
</Base>

<style>
  .ts-page {
    padding: var(--sp-3xl) 0 var(--sp-3xl);
  }

  .ts-hero {
    width: 100%;
    max-width: 760px;
    border-radius: 4px;
    display: block;
    margin-bottom: var(--sp-xl);
  }

  .ts-intro {
    margin: var(--sp-md) 0 var(--sp-lg);
    max-width: 540px;
  }

  /* ── Checklist ── */
  .ts-checklist {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--sp-xl);
    max-width: 760px;
    display: flex;
    flex-direction: column;
    gap: var(--sp-sm);
  }

  .ts-check {
    display: flex;
    align-items: baseline;
    gap: var(--sp-sm);
    font-family: "Public Sans", sans-serif;
    font-size: 15px;
    line-height: 22px;
    color: var(--ak-blueberry);
    transition: opacity 0.2s;
  }

  .ts-check-box {
    font-family: "iA Writer Mono S", monospace;
    font-size: 16px;
    color: var(--ak-hazelnut);
    flex-shrink: 0;
    width: 1.2em;
    transition: color 0.2s;
  }

  .ts-check.done {
    opacity: 0.5;
  }

  .ts-check.done .ts-check-box {
    color: #28c840;
  }

  .ts-all-done {
    display: none;
    font-family: "iA Writer Mono S", monospace;
    font-size: 14px;
    color: #28c840;
    margin-bottom: var(--sp-xl);
    max-width: 760px;
  }

  .ts-mission {
    max-width: 760px;
    margin-bottom: var(--sp-xl);
    display: flex;
    flex-direction: column;
    gap: var(--sp-xs);
  }

  .ts-mission-text {
    font-family: "Public Sans", sans-serif;
    font-size: 16px;
    line-height: 24px;
    color: var(--ak-blueberry);
    margin: 0;
  }

  .ts-mission-start {
    font-family: "Public Sans", sans-serif;
    font-size: 16px;
    line-height: 24px;
    color: var(--ak-blueberry);
    margin: 0;
  }

  .ts-etym {
    color: var(--ak-hazelnut);
    font-size: 14px;
  }

  .ts-code {
    font-family: "iA Writer Mono S", monospace;
    font-size: 14px;
    background: var(--ak-cappuccino);
    color: var(--ak-grape);
    padding: 1px 6px;
    border-radius: 3px;
  }

  /* ── Terminal window chrome ── */
  .ts-window {
    background: #1f1934;
    border-radius: 8px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    max-width: 760px;
    min-height: 420px;
    box-shadow: 0 8px 40px rgba(31, 25, 52, 0.25);
  }

  .ts-titlebar {
    background: #2d2548;
    padding: 10px 16px;
    display: flex;
    align-items: center;
    gap: 6px;
    user-select: none;
  }

  .ts-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .ts-dot--red    { background: #ff5f57; }
  .ts-dot--yellow { background: #febc2e; }
  .ts-dot--green  { background: #28c840; }

  .ts-title {
    font-family: "iA Writer Mono S", monospace;
    font-size: 12px;
    color: #7a6fa0;
    margin-left: auto;
    margin-right: auto;
  }

  /* ── Output area ── */
  .ts-output {
    flex: 1;
    padding: 20px 20px 8px;
    overflow-y: auto;
    font-family: "iA Writer Mono S", monospace;
    font-size: 14px;
    line-height: 1.6;
    color: #eae8e0;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .ts-output :global(.ts-line) {
    display: block;
    margin: 0;
  }

  .ts-output :global(.ts-line--prompt) {
    color: #d8ff01;
  }

  .ts-output :global(.ts-line--muted) {
    color: #7a6fa0;
  }

  .ts-output :global(.ts-line--success) {
    color: #28c840;
  }

  .ts-output :global(.ts-line--error) {
    color: #ff5f57;
  }

  .ts-output :global(.ts-line--accent) {
    color: #5100ff;
  }

  /* ── Input row ── */
  .ts-inputrow {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 20px 16px;
    border-top: 1px solid #2d2548;
  }

  .ts-prompt {
    font-family: "iA Writer Mono S", monospace;
    font-size: 14px;
    color: #d8ff01;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .ts-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    font-family: "iA Writer Mono S", monospace;
    font-size: 14px;
    color: #eae8e0;
    caret-color: #d8ff01;
  }

  .ts-input::placeholder {
    color: #3d3560;
  }

  /* ── Hint below terminal ── */
  .ts-hint {
    margin-top: var(--sp-md);
    font-family: "iA Writer Mono S", monospace;
    font-size: 12px;
    color: #9e9c95;
    max-width: 760px;
  }

  .ts-hint-label {
    color: #5100ff;
    font-weight: bold;
  }

  kbd {
    background: #2d2548;
    color: #d8ff01;
    border-radius: 3px;
    padding: 1px 5px;
    font-family: "iA Writer Mono S", monospace;
    font-size: 11px;
  }

  @media (max-width: 768px) {
    .ts-window { min-height: 360px; border-radius: 6px; }
    .ts-output { font-size: 13px; padding: 14px 14px 6px; }
    .ts-inputrow { padding: 10px 14px 14px; }
    .ts-input { font-size: 13px; }
    .ts-prompt { font-size: 13px; }
  }
</style>

<script is:inline>
(function () {
  const output = document.getElementById('ts-output');
  const input  = document.getElementById('ts-input');

  // ── Fake filesystem ──
  const FILES = {
    'geheimakte.txt': [
      '╔══════════════════════════════════════╗',
      '║       STRENG GEHEIM — LEVEL 5        ║',
      '╚══════════════════════════════════════╝',
      '',
      'Agent: aisu',
      'Status: AKTIV',
      '',
      'Du hast alle Aufgaben erfüllt.',
      'Das System vertraut dir jetzt.',
      '',
      'Nächste Mission: Starte einen echten',
      'Terminal auf deinem eigenen Rechner.',
      '→ lab.aisu.studio/uebungen/hello-my-computer/',
      '',
      '// Ende der Akte //',
    ].join('\n'),

    'passwort.md': [
      'Nein, hier steht kein echtes Passwort.',
      '',
      'Aber gut, dass du nachgeschaut hast —',
      'das ist genau das richtige Instinkt.',
      '',
      'Tipp: Schau auch in geheimakte.txt.',
      '→ tippe:  cat geheimakte.txt',
    ].join('\n'),

    'hallo.py': [
      '# Mein erstes Python-Programm',
      'print("Hallo, Welt!")',
      '',
      '# Starte es mit Thonny — oder lerne',
      '# es bei lab.aisu.studio/uebungen/',
    ].join('\n'),
  };

  // ── Generiere Uptime beim Laden ──
  const uptimeH = Math.floor(Math.random() * 8) + 1;
  const uptimeM = Math.floor(Math.random() * 59) + 1;
  const UPTIME  = uptimeH + ' Stunde' + (uptimeH !== 1 ? 'n' : '') + ' ' + uptimeM + ' Minuten';

  // ── Command history ──
  const history = [];
  let historyIdx = -1;

  // ── Print helpers ──
  function line(text, cls) {
    const span = document.createElement('span');
    span.className = 'ts-line' + (cls ? ' ts-line--' + cls : '');
    span.textContent = text;
    output.appendChild(span);
  }

  function blank() { line(''); }

  function echoCommand(cmd) {
    line('aisu@lab:~$ ' + cmd, 'prompt');
  }

  function scrollDown() {
    output.scrollTop = output.scrollHeight;
  }

  // ── Command definitions ──
  const COMMANDS = {
    help: function () {
      line('Verfügbare Befehle:', 'muted');
      blank();
      const cmds = [
        ['whoami',         'Who am I?',     'Wer bin ich?'],
        ['hostname',       'Host Name',     'Name dieses Rechners'],
        ['ifconfig',       'If Config',     'Netzwerk & IP-Adresse'],
        ['ping [host]',    'Ping',          'Einen anderen Rechner anpingen'],
        ['date',           'Date',          'Datum und Uhrzeit'],
        ['uptime',         'Up Time',       'Wie lange läuft der Rechner?'],
        ['ls',             'List',          'Dateien im Ordner zeigen'],
        ['cat [datei]',    'Concatenate',   'Inhalt einer Datei lesen'],
        ['echo [text]',    'Echo',          'Text ausgeben'],
        ['clear',          'Clear',         'Bildschirm leeren'],
        ['help',           'Help',          'Diese Liste anzeigen'],
      ];
      cmds.forEach(function (c) {
        line('  ' + c[0].padEnd(16) + c[1].padEnd(16) + '→ ' + c[2]);
      });
    },

    whoami: function () { line('aisu'); },

    hostname: function () { line('lab-rechner'); },

    date: function () {
      const now = new Date();
      const days = ['Sonntag','Montag','Dienstag','Mittwoch','Donnerstag','Freitag','Samstag'];
      const months = ['Jan','Feb','Mär','Apr','Mai','Jun','Jul','Aug','Sep','Okt','Nov','Dez'];
      const pad = function (n) { return n < 10 ? '0' + n : '' + n; };
      line(
        days[now.getDay()] + ' ' +
        pad(now.getDate()) + ' ' +
        months[now.getMonth()] + ' ' +
        now.getFullYear() + ' ' +
        pad(now.getHours()) + ':' + pad(now.getMinutes()) + ':' + pad(now.getSeconds())
      );
    },

    uptime: function () { line('up ' + UPTIME); },

    ls: function () {
      line('geheimakte.txt    passwort.md    hallo.py');
    },

    cat: function (args) {
      const filename = args[0];
      if (!filename) {
        line('cat: Dateiname fehlt — Beispiel: cat geheimakte.txt', 'error');
        return;
      }
      if (FILES[filename]) {
        FILES[filename].split('\n').forEach(function (l) { line(l); });
      } else {
        line('cat: ' + filename + ': Datei nicht gefunden', 'error');
      }
    },

    ifconfig: function () {
      line('lo0: flags=8049<UP,LOOPBACK>');
      line('     inet 127.0.0.1');
      line('en0: flags=8863<UP,BROADCAST,RUNNING>');
      line('     inet 192.168.1.' + (Math.floor(Math.random() * 200) + 10) + '  (lokale IP)');
      blank();
      line('Deine externe IP erfährst du mit:  curl ifconfig.me', 'muted');
    },

    curl: function (args) {
      const target = args[0] || '';
      if (target === 'ifconfig.me') {
        line('93.184.' + (Math.floor(Math.random() * 50) + 10) + '.' + (Math.floor(Math.random() * 200) + 10));
      } else {
        line('curl: ' + (target || '(kein Ziel)') + ': im Spiel nicht verfügbar', 'error');
      }
    },

    ping: function (args) {
      const host = args[0] || 'lab.aisu.studio';
      line('PING ' + host);
      var ms = [12, 14, 11, 13];
      ms.forEach(function (t, i) {
        line('64 bytes from ' + host + ': icmp_seq=' + (i+1) + ' ttl=64 time=' + t + ' ms');
      });
      blank();
      line('--- ' + host + ' ping statistics ---');
      line('4 packets transmitted, 4 received, 0% packet loss');
    },

    echo: function (args) {
      line(args.join(' '));
    },

    clear: function () {
      output.innerHTML = '';
    },
  };

  // ── Welcome message ──
  function welcome() {
    line('╔═══════════════════════════════════════════╗');
    line('║   aisu@lab — Terminal-Spiel v1.0          ║');
    line('╚═══════════════════════════════════════════╝');
    blank();
    line('Alle Befehle:  help', 'muted');
    blank();
    scrollDown();
  }

  // ── Checklist ──
  function check(key) {
    const item = document.querySelector('.ts-check[data-cmd="' + key + '"]');
    if (item && !item.classList.contains('done')) {
      item.classList.add('done');
      item.querySelector('.ts-check-box').textContent = '✓';
      const allDone = document.querySelectorAll('.ts-check:not(.done)').length === 0;
      if (allDone) {
        const msg = document.getElementById('ts-alldone');
        if (msg) msg.style.display = 'block';
        import('../../lib/player').then(({ markComplete }) => markComplete('terminal-spiel'));
      }
    }
  }

  // ── Execute command ──
  function run(raw) {
    const trimmed = raw.trim();
    if (!trimmed) return;

    history.unshift(trimmed);
    historyIdx = -1;

    echoCommand(trimmed);

    const parts = trimmed.split(/\s+/);
    const cmd   = parts[0].toLowerCase();
    const args  = parts.slice(1);

    if (COMMANDS[cmd]) {
      COMMANDS[cmd](args);
      // check off matching task
      if (cmd === 'curl' && args[0] === 'ifconfig.me') {
        check('curl ifconfig.me');
      } else if (cmd === 'cat' && args[0] === 'geheimakte.txt') {
        check('cat geheimakte.txt');
      } else {
        check(cmd);
      }
    } else {
      line('bash: ' + cmd + ': command not found — tippe \'help\' für alle Befehle', 'error');
    }

    blank();
    scrollDown();
  }

  // ── Input event ──
  input.addEventListener('keydown', function (e) {
    if (e.key === 'Enter') {
      var val = input.value;
      input.value = '';
      run(val);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      if (historyIdx < history.length - 1) {
        historyIdx++;
        input.value = history[historyIdx];
      }
    } else if (e.key === 'ArrowDown') {
      e.preventDefault();
      if (historyIdx > 0) {
        historyIdx--;
        input.value = history[historyIdx];
      } else {
        historyIdx = -1;
        input.value = '';
      }
    }
  });

  // ── Click anywhere in terminal focuses input ──
  document.querySelector('.ts-window').addEventListener('click', function () {
    input.focus();
  });

  // ── Start ──
  welcome();
  input.focus();
})();
</script>
