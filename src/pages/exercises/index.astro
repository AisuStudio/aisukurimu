---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ExerciseCard from '../../components/ExerciseCard.astro';
import FilterChips from '../../components/FilterChips.astro';
import { url } from '../../lib/url';

const exercises = (await getCollection('exercises'))
  .sort((a, b) => (a.data.session ?? 99) - (b.data.session ?? 99));

// Build filter chip set from the categories actually present
const categories = Array.from(new Set(exercises.map((e) => e.data.category)));
const filters = [
  { id: 'all', label: 'Alle', active: true },
  ...categories.map((c) => ({ id: c, label: c })),
];
---

<Base
  title="Übungen"
  description="Aufgaben und Mini-Projekte für die ersten Schritte als Hacker, Coder, Maker und Systemiker."
>
  <header class="page-head ak-container">
    <p class="ak-eyebrow">Übungs-Blog</p>
    <h1 class="ak-section-title page-title">Übungen</h1>
    <p class="page-lead">
      Praktische Mini-Projekte, von denen jedes etwa 25 bis 90 Minuten dauert.
      Such dir aus, was dich anspricht — du brauchst keine vorherige zu machen.
    </p>
  </header>

  <section class="ak-container page-body">
    <FilterChips label="Kategorie" items={filters} />

    <div class="grid">
      {exercises.map((ex) => (
        <ExerciseCard
          href={url(`/exercises/${ex.id}/`)}
          title={ex.data.title}
          description={ex.data.description}
          tags={ex.data.tags}
          meta={`${ex.data.duration} min · Stufe ${ex.data.difficulty} · ab ${ex.data.ageMin} Jahren`}
        />
      ))}
    </div>
  </section>
</Base>

<style>
  .page-head {
    padding-top: var(--ak-space-7);
    padding-bottom: var(--ak-space-5);
  }
  .page-title {
    margin: var(--ak-space-2) 0 var(--ak-space-3);
  }
  .page-lead {
    font-size: 1.1rem;
    color: var(--ak-ink-soft);
    max-width: 700px;
    margin: 0;
  }
  .page-body {
    padding-bottom: var(--ak-space-8);
  }
  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--ak-space-5);
  }
  @media (min-width: 640px) {
    .grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>
