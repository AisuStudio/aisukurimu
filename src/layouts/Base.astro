---
/*
  Base layout: HTML scaffolding, head meta, global CSS, header/footer.
  All pages compose by wrapping their content in <Base>.

  @font-face declarations live inline here so the url() values can be
  templated with the Astro `base` config — needed for github.io subpath
  deploy. Moving them to global.css would break the live site.
*/
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import NicknameModal from '../components/NicknameModal.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { url } from '../lib/url';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const { title, description = SITE_DESCRIPTION, ogImage } = Astro.props as Props;
const fullTitle = title ? `${title} — ${SITE_TITLE}` : `${SITE_TITLE} — ${SITE_DESCRIPTION}`;
const ogImageUrl = url(ogImage ?? '/images/AK_INDEX_SPLASH.jpg');

const monoRegular = url('/fonts/iA-Writer-Mono-Regular.woff2');
const monoBold    = url('/fonts/iA-Writer-Mono-Bold.woff2');
const sansRegular = url('/fonts/PublicSans-Regular.woff2');
const sansItalic  = url('/fonts/PublicSans-Italic.woff2');
const sansBold    = url('/fonts/PublicSans-Bold.woff2');

const fontFaces = `
@font-face {
  font-family: "Public Sans";
  src: url("${sansRegular}") format("woff2");
  font-weight: 400; font-style: normal; font-display: swap;
}
@font-face {
  font-family: "Public Sans";
  src: url("${sansItalic}") format("woff2");
  font-weight: 400; font-style: italic; font-display: swap;
}
@font-face {
  font-family: "Public Sans";
  src: url("${sansBold}") format("woff2");
  font-weight: 700; font-style: normal; font-display: swap;
}
@font-face {
  font-family: "iA Writer Mono S";
  src: url("${monoRegular}") format("woff2");
  font-weight: 400; font-style: normal; font-display: swap;
}
@font-face {
  font-family: "iA Writer Mono S";
  src: url("${monoBold}") format("woff2");
  font-weight: 700; font-style: normal; font-display: swap;
}
`;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#161633" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={url('/brand/AK_Logo_Blue.svg')} />
    <link rel="sitemap" href={url('/sitemap-index.xml')} />

    {/* Preload the two most-likely-needed font files */}
    <link rel="preload" href={monoRegular} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={sansRegular} as="font" type="font/woff2" crossorigin />

    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImageUrl} />

    <style is:inline set:html={fontFaces} />
  </head>
  <body>
    <div class="wurst-frame" aria-hidden="true">
      <svg class="wurst-svg wurst-svg--back" viewBox="0 0 1400 2000" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
        <g transform="translate(700 1000) scale(0.84 0.6) translate(-700 -1000)">
          <path class="wurst wurst--back"
                vector-effect="non-scaling-stroke"
                d="M 300 -100 C 1600 200 1800 1100 700 1000 C -400 900 1200 1800 400 1700 C -200 1650 1800 2200 900 2400"/>
        </g>
      </svg>
      <svg class="wurst-svg wurst-svg--front" viewBox="0 0 1400 2000" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
        <g transform="translate(700 1000) scale(0.52 0.38) translate(-700 -1000)">
          <path class="wurst wurst--front"
                vector-effect="non-scaling-stroke"
                d="M -142.6 840.3 C 183.8 3.9 1121.3 -301.5 1324.7 201.1 C 1528.1 703.7 -404.1 560 -154.2 1508.6 C 95.7 2457.2 2588.8 -566.6 1592.2 -581.1 C 595.6 -595.6 -539.2 1401.3 -196.5 1256.1"/>
        </g>
      </svg>
    </div>
    <a class="skip-link" href="#main">Zum Inhalt springen</a>
    <Header />
    <NicknameModal />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <style>
      .wurst-frame {
        position: fixed;
        inset: 0;
        z-index: -1;
        overflow: hidden;
        pointer-events: none;
      }

      .wurst-svg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        display: block;
        transform-origin: center center;
      }

      .wurst-svg--back {
        filter: blur(20px);
        transform: scale(1.2) translate(-6%, 4%) rotate(5deg);
      }

      .wurst-svg--front {
        transform: scaleX(-1) rotate(180deg);
      }

      .wurst--front {
        stroke-width: 127;
      }

      .wurst {
        fill: none;
        stroke: var(--wurst-color, #d9ff01);
        stroke-width: 181.74;
        stroke-dasharray: 156.96;
        stroke-linecap: round;
        stroke-linejoin: round;
        animation: wurst-combined linear both;
        animation-timeline: scroll(root block);
      }

      .wurst--back {
        animation-direction: reverse;
      }

      @keyframes wurst-combined {
        0% {
          stroke-dashoffset: 0;
          d: path("M -142.6 840.3 C 183.8 3.9 1121.3 -301.5 1324.7 201.1 C 1528.1 703.7 -404.1 560 -154.2 1508.6 C 95.7 2457.2 2588.8 -566.6 1592.2 -581.1 C 595.6 -595.6 -539.2 1401.3 -196.5 1256.1");
        }
        50% {
          stroke-dashoffset: -500;
          d: path("M 0 -139.1 C -539.7 1396.3 2210.7 261.7 1640 288.9 C 1098.4 314.7 65.2 482 316.2 1430.3 C 713 2929.1 2557.6 1044.7 968.4 990 C -553.5 937.6 -6 2445.1 336.7 2299.9");
        }
        100% {
          stroke-dashoffset: -1000;
          d: path("M -142.6 840.3 C 183.8 3.9 1121.3 -301.5 1324.7 201.1 C 1528.1 703.7 -404.1 560 -154.2 1508.6 C 95.7 2457.2 2588.8 -566.6 1592.2 -581.1 C 595.6 -595.6 -539.2 1401.3 -196.5 1256.1");
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .wurst { animation: none; }
      }

      header, main, footer { position: relative; z-index: 1; }

      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
      }
      .skip-link:focus {
        left: var(--sp-md);
        top: var(--sp-md);
        background: var(--ak-blueberry);
        color: var(--ak-vanilla);
        padding: var(--sp-sm) var(--sp-md);
        z-index: 100;
        border-radius: 4px;
      }
    </style>
  </body>
</html>
