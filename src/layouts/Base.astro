---
/*
  Base layout: HTML scaffolding, head meta, global CSS, header/footer.
  All pages compose by wrapping their content in <Base>.

  @font-face declarations live here (inline) instead of in global.css so the
  url() values can be templated with the Astro `base` config — that way the
  same source works at root and under /aisukurimu/ on github.io.
*/
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { url } from '../lib/url';

interface Props {
  title?: string;
  description?: string;
}

const { title, description = SITE_DESCRIPTION } = Astro.props as Props;
const fullTitle = title ? `${title} — ${SITE_TITLE}` : `${SITE_TITLE} — ${SITE_DESCRIPTION}`;

const fontFaces = `
@font-face {
  font-family: "Public Sans";
  src: url("${url('/fonts/PublicSans-Regular.woff2')}") format("woff2");
  font-weight: 400; font-style: normal; font-display: swap;
}
@font-face {
  font-family: "Public Sans";
  src: url("${url('/fonts/PublicSans-Italic.woff2')}") format("woff2");
  font-weight: 400; font-style: italic; font-display: swap;
}
@font-face {
  font-family: "Public Sans";
  src: url("${url('/fonts/PublicSans-Medium.woff2')}") format("woff2");
  font-weight: 500; font-style: normal; font-display: swap;
}
@font-face {
  font-family: "Public Sans";
  src: url("${url('/fonts/PublicSans-Bold.woff2')}") format("woff2");
  font-weight: 700; font-style: normal; font-display: swap;
}
@font-face {
  font-family: "iA Writer Mono S";
  src: url("${url('/fonts/iAWriterMonoS-Regular.ttf')}") format("truetype");
  font-weight: 400; font-style: normal; font-display: swap;
}
@font-face {
  font-family: "iA Writer Mono S";
  src: url("${url('/fonts/iAWriterMonoS-Bold.ttf')}") format("truetype");
  font-weight: 700; font-style: normal; font-display: swap;
}
`;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={url('/logos/AK_Logo_Mob.svg')} />
    <link rel="sitemap" href={url('/sitemap-index.xml')} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <style is:inline set:html={fontFaces} />
  </head>
  <body>
    <a class="skip-link" href="#main">Zum Inhalt springen</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <style>
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
      }
      .skip-link:focus {
        left: var(--ak-space-4);
        top: var(--ak-space-4);
        background: var(--ak-vanilla-bg);
        color: var(--ak-blueberry-p);
        padding: var(--ak-space-2) var(--ak-space-4);
        z-index: 100;
        border-radius: var(--ak-radius-sm);
      }
    </style>
  </body>
</html>
